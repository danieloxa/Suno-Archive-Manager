{
  "manifest_version": 2,
  "name": "SAM - Suno Archive Manager",
  "version": "1.0.0",
  "description": "Scan and download your entire Suno music library as a local ZIP.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "sidebar_action": {
    "default_panel": "popup/popup.html",
    "default_title": "SAM - Suno Archive Manager",
    "default_icon": "icons/icon48.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "https://*.suno.com/*",
    "https://*.suno.ai/*",
    "https://cdn2.suno.ai/*",
    "https://cdn1.suno.ai/*"
  ],
  "background": {
    "scripts": [
      "lib/jszip.min.js",
      "lib/id3writer.js",
      "background/background-page.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://*.suno.com/*", "https://*.suno.ai/*"],
      "js": ["content/content-script-ff.js"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "archive-master@local",
      "strict_min_version": "109.0"
    }
  }
}
