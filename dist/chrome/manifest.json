{
  "manifest_version": 3,
  "name": "SAM - Suno Archive Manager",
  "version": "1.0.0",
  "description": "Scan and download your entire Suno music library as a local ZIP.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SAM - Suno Archive Manager"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "offscreen",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.suno.com/*",
    "https://*.suno.ai/*",
    "https://cdn2.suno.ai/*",
    "https://cdn1.suno.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.suno.com/*", "https://*.suno.ai/*"],
      "js": ["content/content-script-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.suno.com/*", "https://*.suno.ai/*"],
      "js": ["content/content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
